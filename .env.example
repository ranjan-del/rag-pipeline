# Copy this file to .env and fill in real values.
# NOTE: The pipeline runs fully offline with NO .env at all. Every variable
# below is OPTIONAL and only unlocks a heavier/online backend.

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- LLM (optional) ---
# The default LLM is Anthropic Claude. If ANTHROPIC_API_KEY is unset the pipeline
# falls back to a deterministic extractive answer, so it still runs with no key.
ANTHROPIC_API_KEY=

# --- Optional heavier backends (not required by the default path) ---
# Qdrant vector DB (default is an in-memory numpy store):
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
# QDRANT_COLLECTION=documents
#
# sentence-transformers embeddings (default is a local hashing embedder):
# EMBEDDING_MODEL=all-MiniLM-L6-v2
